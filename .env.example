# ===== KOL TikTok Tracker — environment variables =====
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env)

# Apify API token (เอาจาก https://console.apify.com/account/integrations)
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postgres connection string
# Railway: inject ให้อัตโนมัติจาก Postgres plugin (ไม่ต้องตั้งเอง)
# Local:   ตั้งเองชี้ไปที่ Postgres ในเครื่อง เช่น
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kol

# Secret สำหรับเรียก POST /api/scrape/run เอง (ส่งมาใน header X-ADMIN-KEY)
ADMIN_KEY=change-me-to-a-long-random-string

# Timezone — ใช้คำนวณวันที่ของรอบ scrape (ต้องเป็น Asia/Bangkok)
TZ=Asia/Bangkok

# (optional) Webhook แจ้งเตือนเมื่อ scrape ล้มเหลว (Slack incoming webhook ฯลฯ)
# ALERT_WEBHOOK_URL=
